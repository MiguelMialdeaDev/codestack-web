---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Steps from '~/components/widgets/Steps.astro';
import Stats from '~/components/widgets/Stats.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import { whatsappLink } from '~/navigation';

const metadata = {
  title: 'Codestack — Webs, apps y automatización para tu negocio',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Hablar por WhatsApp',
        href: whatsappLink('Hola Codestack, vengo de tu home y quiero hablar de un proyecto.'),
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
      { text: 'Ver casos', href: '/casos' },
    ]}
  >
    <Fragment slot="title">
      Tu cafetería <span class="text-accent dark:text-white">en internet</span>, sin Glovo, en 7 días.
    </Fragment>

    <Fragment slot="subtitle">
      Web propia con reservas y pedidos directos. Sin pagar 25%
      a Glovo, JustEat o TheFork. Hecho a mano por un developer
      profesional que ya lo construyó para Cafés Maeso (20 años
      en Valencia).
    </Fragment>
  </Hero>

  <!-- ¿Te suena esto? — 3 capas de problema -->
  <Features
    id="problemas"
    tagline="¿Te suena esto?"
    title="Lo que vives cada semana sin presencia digital decente"
    subtitle="Si te identificas con una sola de estas, hay margen para cambiar las cosas."
    items={[
      {
        title: 'No apareces cuando te buscan',
        description:
          'Alguien busca "cafetería cerca" en Google y aparece el local de enfrente. Tu cliente potencial entra ahí en lugar de en tu local. Cada semana, decenas de veces.',
        icon: 'tabler:map-search',
      },
      {
        title: 'Pagas el 25% de cada pedido a plataformas',
        description:
          'Glovo, JustEat, TheFork se llevan entre 25% y 30%. Si haces 1.500 € al mes en pedidos, son 375-450 € que se van. Al año: 4.500-5.400 € que podrías quedarte.',
        icon: 'tabler:cash-off',
      },
      {
        title: 'Tu sobrino lleva 6 meses prometiéndote la web',
        description:
          'Empezó con buenas intenciones, le saliste un trabajo, te dijo "el mes que viene", y el mes que viene se convierte en 8 meses. Mientras tanto, sigues invisible.',
        icon: 'tabler:hourglass-empty',
      },
    ]}
  />

  <!-- Servicios -->
  <Features
    id="servicios"
    tagline="Lo que hago por ti"
    title="Tu negocio digital, montado por una sola persona que sabe lo que hace"
    subtitle="Yo lo construyo, yo lo entrego, yo lo mantengo. Hablas siempre conmigo, no con un comercial. Cuando algo necesita cambiar, cambia."
    items={[
      {
        title: 'Tu local en Google y en el móvil',
        description:
          'Web que carga rápido, se ve perfecta en móvil, y la encuentran cuando buscan tu zona. Más visitas a tu carta, más reservas, más clientes que entran por la puerta.',
        icon: 'tabler:device-mobile',
      },
      {
        title: 'Reservas y pedidos directos sin Glovo',
        description:
          'Tu cliente reserva mesa en 30 segundos. Pedidos a domicilio directos a tu WhatsApp. Cero 25% de comisión. Cero pelearte con TheFork cuando algo falla.',
        icon: 'tabler:calendar-event',
      },
      {
        title: 'Carta digital que actualizas tú mismo',
        description:
          'Cambias el precio del bocadillo en 10 segundos sin reimprimir nada. Tu cliente la ve en su móvil con QR en cada mesa. Adiós a cartas plastificadas viejas.',
        icon: 'tabler:menu-2',
      },
      {
        title: 'Google Maps optimizado para que te encuentren',
        description:
          'Fotos profesionales, reseñas gestionadas, horario actualizado. Apareces antes que la cadena de enfrente cuando alguien busca "cafetería cerca".',
        icon: 'tabler:map-pin',
      },
    ]}
  />

  <!-- Caso destacado 1: Cafés Maeso -->
  <Content
    isReversed
    tagline="Caso de éxito"
    title="Cafés Maeso: tienda online de café de especialidad"
    items={[
      {
        title: '✅ De 0 a 90 productos online en 4 semanas',
        description: 'Tienda completa lanzada en cafesmaeso.es con catálogo de cafés por origen, marca propia y variantes de formato. Pedidos B2C activos desde el día 1.',
      },
      {
        title: '✅ Sin canibalizar el canal B2B de toda la vida',
        description: 'Mantuvieron sus 40+ bares clientes mientras abrían la venta al consumidor final. Misma marca, dos canales bien separados.',
      },
      {
        title: '✅ Web rápida (Core Web Vitals 95+), gestionable por la familia',
        description: 'Panel admin propio que gestionan ellos mismos: pedidos, productos, ofertas. Sin llamarme para cambios diarios.',
      },
      {
        title: 'Stack utilizado',
        description: 'Tienda construida con tecnologías modernas (Next.js + Supabase + Stripe + Resend). Lo importante: funciona, vende y no se cae.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?fit=crop&w=900&h=600',
      alt: 'Café de especialidad',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Cafés Maeso</h3>
      Una marca familiar de café tostado en Valencia con 20 años proveyendo a bares y restaurantes
      decidió dar el salto al ecommerce. Construí su tienda online de cero: arquitectura,
      diseño, integraciones de pago y posicionamiento.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Cómo trabajamos -->
  <Steps
    title="Cómo trabajamos juntos"
    items={[
      {
        title: '1. WhatsApp 15 min, sin compromiso',
        description: 'Me cuentas tu situación y qué te frustra. Yo te digo en plano si encajamos o no. Sin pitch, sin presión.',
        icon: 'tabler:brand-whatsapp',
      },
      {
        title: '2. Propuesta clara en 48h',
        description: 'Alcance + plazo + precio cerrado por escrito. Sin "depende", sin sorpresas a mitad de proyecto.',
        icon: 'tabler:file-text',
      },
      {
        title: '3. Cada lunes ves avance real',
        description: 'Construimos en sprints semanales. Tú lo ves crecer cada semana, no esperas 3 meses a un misterio.',
        icon: 'tabler:calendar-check',
      },
      {
        title: '4. Lanzamos + 30 días de garantía',
        description: 'Despliegue en producción, formación a tu equipo, soporte el primer mes. Después tú decides si seguimos con mantenimiento.',
        icon: 'tabler:rocket',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1531403009284-440f080d1e12?fit=crop&w=900&h=600',
      alt: 'Proceso de trabajo',
    }}
  />

  <!-- Stats orientadas al cliente -->
  <Stats
    title="Lo que esto te ahorra"
    subtitle="Números honestos. Los tuyos pueden ser mayores o menores según tu volumen, pero la dirección es clara."
    stats={[
      { title: '€/año ahorrados en comisiones de Glovo/JustEat', amount: '4.500+' },
      { title: 'Días promedio hasta tener tu web lanzada', amount: '7' },
      { title: 'Tiempo de respuesta a tu WhatsApp', amount: '<24h' },
      { title: 'Permanencia del plan de mantenimiento', amount: '0' },
    ]}
  />

  <!-- FAQs -->
  <FAQs
    title="Preguntas frecuentes"
    subtitle="Lo que más me preguntan antes de empezar a trabajar juntos."
    columns={1}
    items={[
      {
        title: '¿Cómo se calcula el precio?',
        description:
          'Cada proyecto es a medida, así que el precio depende del alcance — qué páginas, qué integraciones, qué funcionalidades. En la llamada gratuita de 30 minutos te lo digo. Si encajamos, en 48h tienes una propuesta con precio cerrado por escrito, sin "depende" ni sorpresas.',
      },
      {
        title: '¿Cuánto tarda en estar lista?',
        description:
          'Una landing: 2-3 días. Web corporativa: 1-2 semanas. Tienda online: 3-5 semanas. App móvil: 6-12 semanas según complejidad. Trabajo en sprints semanales y ves avance real cada lunes.',
      },
      {
        title: '¿Mantenéis la web después?',
        description:
          'Sí, opcional. Plan de mantenimiento desde 80 €/mes incluye hosting, copias de seguridad, actualizaciones de seguridad, monitorización y pequeños cambios mensuales. Sin permanencia.',
      },
      {
        title: '¿Trabajáis con clientes fuera de Valencia?',
        description:
          'Sí. Aunque estoy en Valencia, trabajo en remoto con clientes de toda España. Las reuniones se hacen por videollamada y la documentación queda escrita para que todo esté claro.',
      },
      {
        title: '¿Por qué Codestack y no una agencia grande?',
        description:
          'Porque hablas directamente con el developer que va a construir tu proyecto. Sin comerciales, sin project managers que reenvían correos, sin "lo consulto con el equipo". Comunicación directa, decisiones rápidas, precios sin la grasa de una agencia.',
      },
    ]}
  />

  <!-- CTA final -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Hablar por WhatsApp',
        href: whatsappLink('Hola Codestack, tengo una idea/problema en mente y quiero contarlo.'),
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
      {
        text: 'Prefiero email',
        href: '/contact',
        icon: 'tabler:mail',
      },
    ]}
  >
    <Fragment slot="title">
      Sé el dueño al que llaman directamente, no a las plataformas
    </Fragment>

    <Fragment slot="subtitle">
      En 7 días tu cafetería puede tener su propia web, recibir reservas
      sin pasar por TheFork y pedidos sin ceder 25% a Glovo. Mándame
      WhatsApp y lo hablamos en 15 minutos, sin compromiso.
    </Fragment>
  </CallToAction>
</Layout>
