---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Steps from '~/components/widgets/Steps.astro';
import Stats from '~/components/widgets/Stats.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Codestack — Webs, apps y automatización para tu negocio',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Pide presupuesto',
        href: '/contact',
        icon: 'tabler:mail',
      },
      { text: 'Ver casos', href: '/casos' },
    ]}
  >
    <Fragment slot="title">
      El <span class="text-accent dark:text-white">stack completo</span> de tu negocio: web, app y automatización
    </Fragment>

    <Fragment slot="subtitle">
      Desarrollo a medida hecho por un developer real, no una plantilla.
      Webs rápidas, apps Android nativas y procesos automatizados para
      negocios que quieren más clientes con menos esfuerzo.
    </Fragment>
  </Hero>

  <!-- Servicios -->
  <Features
    id="servicios"
    tagline="Servicios"
    title="Todo lo que tu negocio digital necesita, en un solo sitio"
    subtitle="No subcontrato. Yo construyo, yo entrego, yo mantengo. Resultado: comunicación directa, sin intermediarios, sin sorpresas de calidad."
    items={[
      {
        title: 'Webs a medida',
        description:
          'Webs corporativas, landing pages y tiendas online con Astro o Next.js. Rápidas, SEO-ready y diseñadas para convertir visitas en clientes.',
        icon: 'tabler:world-www',
      },
      {
        title: 'Apps Android',
        description:
          'Apps nativas con Kotlin + Jetpack Compose. 7 años de experiencia desarrollando para banca, retail y movilidad. Publicación en Play Store incluida.',
        icon: 'tabler:device-mobile',
      },
      {
        title: 'Automatización',
        description:
          'Bots, scrapers, integraciones y procesos automáticos que te ahorran horas semanales. Casos reales: alertas Telegram, gestión de inventario, notificaciones.',
        icon: 'tabler:robot',
      },
      {
        title: 'SEO y mantenimiento',
        description:
          'Posicionamiento orgánico, optimización de rendimiento y mantenimiento técnico para que tu web crezca sin caerse. Sin contratos eternos.',
        icon: 'tabler:trending-up',
      },
    ]}
  />

  <!-- Caso destacado 1: Cafés Maeso -->
  <Content
    isReversed
    tagline="Caso de éxito"
    title="Cafés Maeso: tienda online de café de especialidad"
    items={[
      {
        title: 'Stack técnico',
        description: 'Next.js 16 + Supabase + Stripe + Resend. Catálogo de 90 SKUs, suscripciones recurrentes, panel admin.',
      },
      {
        title: 'Reto',
        description: 'Tueste familiar con 20 años de historia B2B que necesitaba salto al online sin perder identidad artesanal.',
      },
      {
        title: 'Resultado',
        description: 'Tienda en producción en cafesmaeso.es con catálogo completo, checkout funcionando y narrativa de marca consistente.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?fit=crop&w=900&h=600',
      alt: 'Café de especialidad',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Cafés Maeso</h3>
      Una marca familiar de café tostado en Valencia con 20 años proveyendo a bares y restaurantes
      decidió dar el salto al ecommerce. Construí su tienda online de cero: arquitectura,
      diseño, integraciones de pago y posicionamiento.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Caso destacado 2: WarrantyVault -->
  <Content
    tagline="Caso de éxito"
    title="WarrantyVault: app Android publicada en Play Store"
    items={[
      {
        title: 'Stack técnico',
        description: 'Kotlin + Jetpack Compose + Clean Architecture multi-módulo. Room, DataStore, WorkManager, Google Play Billing v6.',
      },
      {
        title: 'Reto',
        description: 'Gestor de garantías 100% local que no envía datos a servidores. Privacidad como diferenciador en categoría productividad.',
      },
      {
        title: 'Resultado',
        description: 'App publicada con suscripción premium, política de privacidad real y arquitectura escalable para añadir features.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1551650975-87deedd944c3?fit=crop&w=900&h=600',
      alt: 'App Android en uso',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">WarrantyVault</h3>
      App propia desarrollada de principio a fin: idea, diseño, código, build firmado,
      tienda Google Play, política de privacidad, monetización. El proceso completo de
      llevar una app a producción, replicable para cualquier cliente.
    </Fragment>
  </Content>

  <!-- Cómo trabajamos -->
  <Steps
    title="Cómo trabajamos juntos"
    items={[
      {
        title: '1. Llamada inicial gratuita',
        description: 'Te escucho, entiendo el problema real, te digo si encajamos. 30 minutos sin compromiso.',
        icon: 'tabler:phone',
      },
      {
        title: '2. Propuesta clara y por escrito',
        description: 'En 48h tienes una propuesta con alcance, plazo y precio cerrado. Sin "depende".',
        icon: 'tabler:file-text',
      },
      {
        title: '3. Construimos en sprints semanales',
        description: 'Cada semana ves avance real, no promesas. Iteramos rápido con tu feedback.',
        icon: 'tabler:code',
      },
      {
        title: '4. Lanzamos y acompañamos',
        description: 'Despliegue en producción, formación y 30 días de garantía. Después tú decides si seguimos.',
        icon: 'tabler:rocket',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1531403009284-440f080d1e12?fit=crop&w=900&h=600',
      alt: 'Proceso de trabajo',
    }}
  />

  <!-- Stats -->
  <Stats
    title="Por qué Codestack"
    subtitle="Números que respaldan el trabajo, no promesas de marketing."
    stats={[
      { title: 'Años de experiencia Android', amount: '7+' },
      { title: 'Proyectos en producción', amount: '3' },
      { title: 'Stacks dominados', amount: '5' },
      { title: 'Cliente medio responde en', amount: '<2h' },
    ]}
  />

  <!-- FAQs -->
  <FAQs
    title="Preguntas frecuentes"
    subtitle="Lo que más me preguntan antes de empezar a trabajar juntos."
    columns={1}
    items={[
      {
        title: '¿Cuánto cuesta una web?',
        description:
          'Depende del alcance, pero como referencia: una landing page corporativa simple parte de 800 €. Una web completa con varias secciones y casos: 1.500-2.500 €. Una tienda online con pasarela de pago e inventario: 2.500-5.000 €. Te doy precio cerrado en la propuesta, sin sorpresas.',
      },
      {
        title: '¿Cuánto tarda en estar lista?',
        description:
          'Una landing: 1-2 semanas. Web corporativa: 3-4 semanas. Tienda online: 5-8 semanas. Apps Android: 8-16 semanas según complejidad. Trabajo en sprints semanales y ves avance real cada lunes.',
      },
      {
        title: '¿Mantenéis la web después?',
        description:
          'Sí, opcional. Plan de mantenimiento desde 80 €/mes incluye hosting, copias de seguridad, actualizaciones de seguridad, monitorización y pequeños cambios mensuales. Sin permanencia.',
      },
      {
        title: '¿Trabajáis con clientes fuera de Valencia?',
        description:
          'Sí. Aunque estoy en Valencia, trabajo en remoto con clientes de toda España. Las reuniones se hacen por videollamada y la documentación queda escrita para que todo esté claro.',
      },
      {
        title: '¿Por qué Codestack y no una agencia grande?',
        description:
          'Porque hablas directamente con el developer que va a construir tu proyecto. Sin comerciales, sin project managers que reenvían correos, sin "lo consulto con el equipo". Comunicación directa, decisiones rápidas, precios sin la grasa de una agencia.',
      },
    ]}
  />

  <!-- CTA final -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Pide presupuesto',
        href: '/contact',
        icon: 'tabler:mail',
      },
    ]}
  >
    <Fragment slot="title">
      ¿Tienes una idea o un problema en mente?
    </Fragment>

    <Fragment slot="subtitle">
      Cuéntamelo en 30 minutos por videollamada. Si encajamos, en 48h
      tienes propuesta por escrito. Si no, te diré con quién hablar.
    </Fragment>
  </CallToAction>
</Layout>
