---
import Layout from '~/layouts/PageLayout.astro';

import HeroText from '~/components/widgets/HeroText.astro';
import Content from '~/components/widgets/Content.astro';
import Steps from '~/components/widgets/Steps.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import { whatsappLink } from '~/navigation';

const metadata = {
  title: 'Servicios',
  description:
    'Webs a medida, apps móviles nativas, automatización de procesos y SEO técnico. Desarrollo full-stack por un developer real, sin intermediarios.',
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <HeroText
    tagline="Servicios"
    title="Todo el stack digital de tu negocio, hecho a medida"
    subtitle="No subcontrato. No uso plantillas no-code. No firmo contratos de permanencia. Lo que entrego lo construyo yo, con tecnologías modernas, y queda pensado para crecer contigo."
  />

  <!-- ====================================== -->
  <!-- 1. WEBS A MEDIDA -->
  <!-- ====================================== -->
  <Content
    id="web"
    isReversed
    tagline="Webs a medida"
    title="Webs corporativas, landing pages y tiendas online"
    items={[
      {
        title: 'Webs corporativas',
        description:
          'Para empresas que quieren una presencia profesional, rápida y mantenible. Múltiples páginas, blog opcional, formulario de contacto, integraciones básicas.',
      },
      {
        title: 'Landing pages de conversión',
        description:
          'Una sola página enfocada a un único objetivo: captar leads, vender un producto, recoger inscripciones. Optimizada para móvil y para tráfico de ads.',
      },
      {
        title: 'Tiendas online (ecommerce)',
        description:
          'Catálogo, carrito, checkout con Stripe, gestión de pedidos, emails transaccionales. Suscripciones recurrentes si encaja con tu producto.',
      },
      {
        title: 'Stack: Astro o Next.js · Tailwind · Supabase · Stripe · Cloudflare',
        description:
          'Tecnologías modernas pensadas para velocidad, SEO y costes de hosting bajos. Sin WordPress, sin plugins frágiles, sin sorpresas anuales en facturas.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1467232004584-a241de8bcf5d?fit=crop&w=900&h=600',
      alt: 'Diseño web a medida',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Webs que rinden, no solo "que se ven bien"</h3>
      Una web bonita que tarda 8 segundos en cargar pierde el 70% de los visitantes
      antes de que vean nada. Construyo webs rápidas (Core Web Vitals 95+), con SEO técnico
      desde el día 1, y diseñadas para convertir el tráfico que ya tienes.
    </Fragment>
  </Content>

  <!-- ====================================== -->
  <!-- 2. APPS MÓVILES -->
  <!-- ====================================== -->
  <Content
    id="movil"
    tagline="Apps móviles"
    title="Apps móviles nativas con arquitectura limpia"
    items={[
      {
        title: 'Apps de productividad',
        description:
          'Herramientas que el usuario abre cada semana: gestores, trackers, listas, recordatorios. UX simple, funcionamiento offline, monetización opcional vía suscripción.',
      },
      {
        title: 'Apps corporativas internas',
        description:
          'Para tu equipo de campo, comerciales o almacén. Sincronización con tu backend, login, permisos por rol. Distribución privada (no Play Store pública).',
      },
      {
        title: 'Acompañantes de tu negocio físico',
        description:
          'App para clientes fidelizados: cartas digitales, reservas, pedidos, programas de puntos. Integrada con tu web o sistema POS si lo tienes.',
      },
      {
        title: 'Stack: Kotlin · Jetpack Compose · Clean Architecture · Room · Google Play Billing',
        description:
          'Apps nativas (no híbridas), multi-módulo, testeable, con publicación en Play Store incluida. Material 3, accesibilidad TalkBack, soporte multi-idioma.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1512941937669-90a1b58e7e9c?fit=crop&w=900&h=600',
      alt: 'App móvil nativa',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">+5 años desarrollando para banca, retail y movilidad</h3>
      Sé exactamente qué es una app preparada para producción y qué es un prototipo.
      Si tu app va a tener usuarios reales, necesita arquitectura, tests y proceso
      de release. Si no, te ahorras dinero haciéndola como prototipo y la rehacemos
      cuando crezca.
    </Fragment>
  </Content>

  <!-- ====================================== -->
  <!-- 3. AUTOMATIZACIÓN -->
  <!-- ====================================== -->
  <Content
    id="automation"
    isReversed
    tagline="Automatización"
    title="Procesos que se ejecutan solos, 24/7"
    items={[
      {
        title: 'Bots de Telegram',
        description:
          'Alertas automáticas a tu móvil cuando pasa algo importante: nuevo lead, pedido grande, métrica fuera de rango, mención en redes sociales.',
      },
      {
        title: 'Scrapers y monitorización',
        description:
          'Vigilar precios de competencia, disponibilidad de stock en proveedores, ofertas que aparecen en marketplaces. Aviso automático cuando cumpla tus criterios.',
      },
      {
        title: 'Integraciones entre tus herramientas',
        description:
          'Conectar lo que usas (Stripe, Notion, Google Sheets, Airtable, tu web, tu CRM) para que los datos fluyan sin copiar-pegar a mano.',
      },
      {
        title: 'Stack: Python · GitHub Actions · Cloudflare Workers · APIs REST · Telegram Bot API',
        description:
          'Infraestructura barata (GitHub Actions tier gratis cubre la mayoría de casos) o serverless. Sin servidores propios que mantener.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1518770660439-4636190af475?fit=crop&w=900&h=600',
      alt: 'Automatización de procesos',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Si lo haces más de 2 veces por semana, debería automatizarse</h3>
      Una hora a la semana revisando manualmente algo = 50 horas al año. Una
      automatización de 4 horas se amortiza el primer mes y trabaja para ti
      gratis el resto del año.
    </Fragment>
  </Content>

  <!-- ====================================== -->
  <!-- 4. SEO + MANTENIMIENTO -->
  <!-- ====================================== -->
  <Content
    id="seo"
    tagline="SEO y mantenimiento"
    title="Que tu web aparezca cuando te buscan y no se caiga nunca"
    items={[
      {
        title: 'SEO técnico',
        description:
          'Auditoría Core Web Vitals, schema.org, sitemap, robots, redirecciones, canonicals. Lo que Google necesita para entender tu web y rankearla.',
      },
      {
        title: 'SEO local (Valencia + España)',
        description:
          'Google Business Profile, NAP consistency, citaciones locales, contenido orientado a búsquedas geo-localizadas ("[servicio] en [ciudad]").',
      },
      {
        title: 'Mantenimiento técnico',
        description:
          'Hosting, copias de seguridad automáticas, actualizaciones de seguridad, monitorización 24/7, pequeños cambios mensuales. Sin contratos eternos.',
      },
      {
        title: 'Optimización continua',
        description:
          'Una vez la web está viva, mejoramos sobre datos reales: qué páginas convierten, qué keywords ranquean, qué partes pierden visitantes. Iteración mensual.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?fit=crop&w=900&h=600',
      alt: 'SEO y analítica',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">SEO honesto: meses, no semanas</h3>
      El SEO real tarda 3-6 meses en mover el ranking. Cualquiera que te prometa
      "primera posición en 7 días" o usa black hat (que Google te penalice tarde
      o temprano) o te miente directamente. Aquí trabajo con plazos honestos
      y métricas verificables.
    </Fragment>
  </Content>

  <!-- ====================================== -->
  <!-- Cómo trabajamos -->
  <!-- ====================================== -->
  <Steps
    title="Cómo trabajamos juntos"
    items={[
      {
        title: '1. Llamada inicial gratuita (30 min)',
        description: 'Te escucho, entiendo el problema real, te digo si encajamos. Sin compromiso, sin pitch agresivo.',
        icon: 'tabler:phone',
      },
      {
        title: '2. Propuesta por escrito en 48h',
        description: 'Alcance, plazo y precio cerrado. Sin "depende", sin sorpresas a mitad de proyecto.',
        icon: 'tabler:file-text',
      },
      {
        title: '3. Sprints semanales con avance real',
        description: 'Cada lunes ves progreso visible, no promesas. Iteramos rápido con tu feedback.',
        icon: 'tabler:code',
      },
      {
        title: '4. Lanzamiento + 30 días de garantía',
        description: 'Despliegue, formación y un mes de soporte incluido. Después tú decides si seguimos con mantenimiento.',
        icon: 'tabler:rocket',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1531403009284-440f080d1e12?fit=crop&w=900&h=600',
      alt: 'Proceso de trabajo',
    }}
  />

  <!-- ====================================== -->
  <!-- CTA final -->
  <!-- ====================================== -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Hablar por WhatsApp',
        href: whatsappLink('Hola Codestack, vengo de la página de servicios y quiero hablar de un proyecto.'),
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
      {
        text: 'Ver casos',
        href: '/casos',
      },
    ]}
  >
    <Fragment slot="title">¿Cuál de los 4 servicios te encaja?</Fragment>

    <Fragment slot="subtitle">
      Cuéntamelo en 30 minutos sin compromiso. Si encajamos, en 48h tienes
      propuesta por escrito con alcance y precio cerrado.
    </Fragment>
  </CallToAction>
</Layout>
