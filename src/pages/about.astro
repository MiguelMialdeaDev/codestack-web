---
import Layout from '~/layouts/PageLayout.astro';

import HeroText from '~/components/widgets/HeroText.astro';
import Content from '~/components/widgets/Content.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import { whatsappLink } from '~/navigation';

const metadata = {
  title: 'Sobre Codestack — Miguel Mialdea',
  description:
    'Soy Miguel, developer profesional con +5 años en consultoras tech. Vivo en Valencia. Construí cafesmaeso.es. Codestack es mi marca para ayudar a cafeterías y restaurantes a tener presencia digital sin depender de plataformas.',
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <HeroText
    tagline="Sobre Codestack"
    title="Soy Miguel. Construyo webs para que tu cafetería no dependa de Glovo."
    subtitle="Esto es Codestack: una persona, no una agencia. Hablas conmigo, decides conmigo, y conmigo se construye lo que llevas a producción."
  />

  <!-- Quién soy -->
  <Content
    isReversed
    tagline="Quién soy"
    title="Developer profesional desde hace más de 5 años"
    items={[
      {
        title: 'Día a día',
        description:
          'Trabajo a jornada completa como Android Developer en una consultora tecnológica internacional. He pasado por proyectos de banca, retail y movilidad para clientes en producción.',
      },
      {
        title: 'Stack',
        description:
          'Kotlin, Jetpack Compose, Clean Architecture multi-módulo, Room, WorkManager, testing con JUnit/MockK/Turbine. También Next.js, Astro, Supabase y Stripe en el lado web.',
      },
      {
        title: 'Por qué Codestack',
        description:
          'Después de muchos proyectos enterprise, vi que los negocios pequeños de mi ciudad — cafeterías, restaurantes, talleres — tenían webs penosas o ninguna, y pagaban 25 % a plataformas que se llevan su margen. Codestack existe para resolver exactamente eso.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1531403009284-440f080d1e12?fit=crop&w=900&h=600',
      alt: 'Developer trabajando',
    }}
  />

  <!-- Por qué Valencia -->
  <Content
    tagline="Por qué Valencia"
    title="Vivo aquí. Mi cliente está al lado de mi casa."
    items={[
      {
        title: 'Conozco el mercado local',
        description:
          'He tomado café en la mayoría de cafeterías independientes de la zona. Sé qué cadena llega a qué barrio. Sé qué dueño está pensando "esto del online me supera". Tu situación no es teoría para mí.',
      },
      {
        title: 'Reuniones presenciales si encajan',
        description:
          'Para proyectos que lo merezcan, voy a tu local. 15 minutos, un café, decisión. Mucho más eficiente que tres videollamadas y un PDF.',
      },
      {
        title: 'Soporte cercano',
        description:
          'Cuando algo no va, no escribes a un soporte de Mumbai. Me escribes a mí. Vivo a 20 minutos en metro de la mayoría de cafés de Valencia.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1568376794508-ae52c6ab3929?fit=crop&w=900&h=600',
      alt: 'Valencia',
    }}
  />

  <!-- Caso anchor Maeso -->
  <Content
    isReversed
    tagline="El caso que respalda todo lo demás"
    title="Cafés Maeso: 20 años en Valencia, ahora también online"
    items={[
      {
        title: '¿Por qué confían en mí?',
        description:
          'Porque construí su tienda online de cero (cafesmaeso.es) y hoy venden al consumidor final sin perder a los bares de toda la vida. Misma marca, dos canales, cero canibalización.',
      },
      {
        title: 'Lo que les entregué',
        description:
          'Catálogo de 90 SKUs, suscripciones recurrentes, panel admin que gestionan ellos mismos, pagos con Stripe y envíos a toda España. Todo en 4 semanas.',
      },
      {
        title: 'Lo que pueden hacer ellos solos',
        description:
          'Subir productos, cambiar precios, gestionar pedidos, exportar facturas. No me llaman cada semana — solo cuando hay cambios mayores. Esa es la idea.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1442550528053-c431ecb55509?fit=crop&w=900&h=600',
      alt: 'Tueste de café Maeso',
    }}
    callToAction={{
      target: '_self',
      text: 'Ver caso completo →',
      href: '/casos/cafes-maeso',
    }}
  />

  <!-- Cómo trabajo -->
  <Stats
    title="Cómo trabajo (en números honestos)"
    subtitle="No prometo lo que no puedo cumplir. Estos son los compromisos reales."
    stats={[
      { title: 'Respondo tu WhatsApp en menos de', amount: '24h' },
      { title: 'Propuesta por escrito tras la primera llamada', amount: '48h' },
      { title: 'Días promedio hasta tu web lanzada', amount: '7' },
      { title: 'Permanencia del plan de mantenimiento', amount: '0' },
    ]}
  />

  <!-- CTA -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Hablar por WhatsApp',
        href: whatsappLink('Hola Miguel, vi tu página de Sobre y me gustaría hablar de un proyecto.'),
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
      {
        text: 'Ver pricing',
        href: '/#pricing',
      },
    ]}
  >
    <Fragment slot="title">¿Encajamos?</Fragment>

    <Fragment slot="subtitle">
      La única forma de saberlo es hablar 15 minutos sin compromiso.
      Si encajamos, en 48 horas tienes propuesta por escrito.
    </Fragment>
  </CallToAction>
</Layout>
