---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Steps from '~/components/widgets/Steps.astro';
import Stats from '~/components/widgets/Stats.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import { whatsappLink } from '~/navigation';

const metadata = {
  title: 'Codestack — Web, apps and automation for your business',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Talk on WhatsApp',
        href: whatsappLink('Hi Codestack, I came from your home page and would like to talk about a project.'),
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
      { text: 'See cases', href: '/en/cases' },
    ]}
  >
    <Fragment slot="title">
      Your café <span class="text-accent dark:text-white">online</span>, without Glovo, in 7 days.
    </Fragment>

    <Fragment slot="subtitle">
      Your own website with direct reservations and orders. No 25%
      commissions to Glovo, JustEat or TheFork. Hand-built by a real
      developer who already did it for Cafés Maeso (20 years in Valencia).
    </Fragment>
  </Hero>

  <!-- Does this sound familiar? — 3 problem layers -->
  <Features
    id="problems"
    tagline="Does this sound familiar?"
    title="What you live every week without decent digital presence"
    subtitle="If you identify with even one of these, there is room to change things."
    items={[
      {
        title: 'You do not appear when they search',
        description:
          'Someone searches "café near me" on Google and the place across the street shows up. Your potential client walks in there instead of into your café. Every week, dozens of times.',
        icon: 'tabler:map-search',
      },
      {
        title: 'You pay 25% of each order to platforms',
        description:
          'Glovo, JustEat, TheFork take between 25% and 30%. If you do €1,500/month in orders, that is €375-450 going out. Per year: €4,500-5,400 you could keep.',
        icon: 'tabler:cash-off',
      },
      {
        title: 'Your nephew has promised you the website for 6 months',
        description:
          'Started with good intentions, got busy, told you "next month", and "next month" turned into 8 months. Meanwhile, you stay invisible.',
        icon: 'tabler:hourglass-empty',
      },
    ]}
  />

  <!-- Services -->
  <Features
    id="services"
    tagline="What I do for you"
    title="Your digital business, built by one person who knows what they're doing"
    subtitle="I build it, I deliver it, I maintain it. You always talk directly to me, not a sales rep. When something needs to change, it changes."
    items={[
      {
        title: 'Your café on Google and on the phone',
        description:
          'Website that loads fast, looks great on mobile, and gets found when people search your area. More menu views, more reservations, more clients walking in.',
        icon: 'tabler:device-mobile',
      },
      {
        title: 'Direct reservations and orders, no Glovo',
        description:
          'Your client books a table in 30 seconds. Delivery orders go straight to your WhatsApp. Zero 25% commission. Zero fighting with TheFork when something breaks.',
        icon: 'tabler:calendar-event',
      },
      {
        title: 'Digital menu you update yourself',
        description:
          'Change the sandwich price in 10 seconds without reprinting anything. Your client sees it on their phone via QR at each table. Goodbye to old laminated menus.',
        icon: 'tabler:menu-2',
      },
      {
        title: 'Google Maps optimized so they find you',
        description:
          'Professional photos, managed reviews, updated hours. You appear before the chain across the street when someone searches "café near me".',
        icon: 'tabler:map-pin',
      },
    ]}
  />

  <!-- Featured case 1: Cafés Maeso -->
  <Content
    isReversed
    tagline="Success case"
    title="Cafés Maeso: specialty coffee online store"
    items={[
      {
        title: '✅ From 0 to 90 products online in 4 weeks',
        description: 'Complete store launched at cafesmaeso.es with coffees by origin, own brand and format variants. B2C orders active from day 1.',
      },
      {
        title: '✅ Without cannibalizing their 20-year B2B channel',
        description: 'Kept their 40+ bar clients while opening direct-to-consumer sales. Same brand, two well-separated channels.',
      },
      {
        title: '✅ Fast website (Core Web Vitals 95+), managed by the family',
        description: 'Custom admin panel they manage themselves: orders, products, offers. No daily calls needed for changes.',
      },
      {
        title: 'Tech stack used',
        description: 'Built with modern technologies (Next.js + Supabase + Stripe + Resend). What matters: it works, it sells, it does not break.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?fit=crop&w=900&h=600',
      alt: 'Specialty coffee',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Cafés Maeso</h3>
      A family coffee roaster in Valencia with 20 years supplying bars and restaurants
      decided to make the jump to ecommerce. I built their online store from scratch:
      architecture, design, payment integrations and positioning.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- How we work -->
  <Steps
    title="How we work together"
    items={[
      {
        title: '1. 15-min WhatsApp, no commitment',
        description: 'You tell me your situation and what frustrates you. I tell you straight if we fit or not. No pitch, no pressure.',
        icon: 'tabler:brand-whatsapp',
      },
      {
        title: '2. Clear proposal within 48h',
        description: 'Scope + timeline + fixed price in writing. No "it depends", no surprises mid-project.',
        icon: 'tabler:file-text',
      },
      {
        title: '3. Every Monday you see real progress',
        description: 'We build in weekly sprints. You watch it grow each week, not wait 3 months for a mystery.',
        icon: 'tabler:calendar-check',
      },
      {
        title: '4. Launch + 30-day guarantee',
        description: 'Production deployment, training for your team, support the first month. Afterwards you decide if we continue with maintenance.',
        icon: 'tabler:rocket',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1531403009284-440f080d1e12?fit=crop&w=900&h=600',
      alt: 'Work process',
    }}
  />

  <!-- Stats — client-oriented -->
  <Stats
    title="What this saves you"
    subtitle="Honest numbers. Yours may be larger or smaller depending on your volume, but the direction is clear."
    stats={[
      { title: '€/year saved in Glovo/JustEat commissions', amount: '4,500+' },
      { title: 'Days average until your website is live', amount: '7' },
      { title: 'Response time to your WhatsApp', amount: '<24h' },
      { title: 'Lock-in period on maintenance plan', amount: '0' },
    ]}
  />

  <!-- FAQs -->
  <FAQs
    title="Frequently asked questions"
    subtitle="The questions I get most before starting to work together."
    columns={1}
    items={[
      {
        title: 'How is the price calculated?',
        description:
          'Every project is custom, so the price depends on the scope — which pages, which integrations, which features. I tell you in the free 30-minute call. If we fit, within 48h you get a proposal with fixed price in writing, no "it depends" or surprises.',
      },
      {
        title: 'How long does it take to launch?',
        description:
          'Landing page: 2-3 days. Corporate website: 1-2 weeks. Online store: 3-5 weeks. Mobile app: 6-12 weeks depending on complexity. I work in weekly sprints and you see real progress every Monday.',
      },
      {
        title: 'Do you maintain the website afterwards?',
        description:
          'Yes, optional. Maintenance plan from €80/month includes hosting, backups, security updates, monitoring and small monthly changes. No long-term commitment.',
      },
      {
        title: 'Do you work with clients outside Valencia?',
        description:
          'Yes. Although I am based in Valencia, I work remotely with clients across Spain and internationally. Meetings are done via video call and documentation is kept in writing for clarity.',
      },
      {
        title: 'Why Codestack and not a big agency?',
        description:
          'Because you talk directly to the developer building your project. No salespeople, no project managers forwarding emails, no "let me check with the team". Direct communication, fast decisions, prices without the agency overhead.',
      },
    ]}
  />

  <!-- Final CTA -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Talk on WhatsApp',
        href: whatsappLink('Hi Codestack, I have an idea/problem in mind and would like to discuss it.'),
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
      {
        text: 'I prefer email',
        href: '/en/contact',
        icon: 'tabler:mail',
      },
    ]}
  >
    <Fragment slot="title">
      Be the owner they call directly, not the platforms
    </Fragment>

    <Fragment slot="subtitle">
      In 7 days your café can have its own website, take reservations
      without going through TheFork, and orders without giving up 25%
      to Glovo. Send me a WhatsApp and we talk in 15 minutes,
      no commitment.
    </Fragment>
  </CallToAction>
</Layout>
