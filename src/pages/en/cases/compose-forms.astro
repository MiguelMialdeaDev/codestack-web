---
import Layout from '~/layouts/PageLayout.astro';

import HeroText from '~/components/widgets/HeroText.astro';
import Content from '~/components/widgets/Content.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import { whatsappLink } from '~/navigation';

const metadata = {
  title: 'Compose Forms — Open source Android library',
  description:
    'Case study: open source library for reactive forms in Jetpack Compose with type-safe validation via KSP, published on Maven Central.',
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Case · Open Source · Tech library"
    title="Compose Forms"
    subtitle="Open source library for reactive forms in Jetpack Compose with type-safe validation generated by KSP. Built for professional developers, published on Maven Central."
  />

  <Content
    isReversed
    tagline="Context"
    title="A real gap in the Android ecosystem"
    items={[
      {
        title: 'State of the art 2026',
        description:
          'Form Conductor (3+ years without release), rootstrap/FlowForms (unmaintained), the rest runtime DSL or tutorials. Nobody combined KSP + multi-step + async validators + Compose-first.',
      },
      {
        title: 'TextFieldState does not compete',
        description:
          'Compose 1.7+ introduced TextFieldState, but it does not solve the type-safe schema part, nor async validation, nor multi-step. Gap confirmed after audit.',
      },
      {
        title: 'Why build it',
        description:
          'Demonstrate technical capability beyond commercial apps: KSP, code generation, API design, publishing pipeline to Maven Central. Portfolio piece that validates seniority.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1555066931-4365d14bab8c?fit=crop&w=900&h=600',
      alt: 'Kotlin code',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">The challenge</h3>
      Build a technical library that fills a real gap, with clean API, validated
      with tests, and published with the same rigor as Google's official
      libraries.
    </Fragment>
  </Content>

  <Content
    tagline="Architecture"
    title="7 modules with aggressive split for tree-shaking"
    items={[
      {
        title: 'annotations',
        description:
          '@FormSpec + @Field source-retention. No runtime overhead. Zero dependencies in client code.',
      },
      {
        title: 'runtime + compose',
        description:
          'FieldState<T> with 400ms debounce, cancellation, short-circuit in sync validation, touched tracking. collectValueAsState() for Compose.',
      },
      {
        title: 'compiler (KSP)',
        description:
          'SymbolProcessor that generates <Name>State + DSL builder + remember<Name>State() at compile time. No reflection, no runtime surprises.',
      },
      {
        title: 'validators + async',
        description:
          'Optional BuiltinValidators (required, email, matches) + AsyncValidators.remote for backend validation with proper cancellation.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1517694712202-14dd9538aa97?fit=crop&w=900&h=600',
      alt: 'Software architecture',
    }}
  />

  <Content
    isReversed
    tagline="Tech stack"
    title="Kotlin 2.1 + KSP2 + Compose + Maven Central"
    items={[
      {
        title: 'Modern build',
        description:
          'AGP 8.7+, Kotlin 2.1 with K2 + KSP2, JVM17, minSdk24, targetSdk35. Own convention plugins (Android lib, JVM lib, Compose lib).',
      },
      {
        title: 'Testing',
        description:
          'JUnit + Turbine + Kotest. Critical cases covered: untouched, sync flow, short-circuit, async Pending→Result, async skipped when sync fails.',
      },
      {
        title: 'CI/CD',
        description:
          'GitHub Actions with Compose 1.7/1.8/1.9 matrix. ktfmt pre-commit. Manual CHANGELOG Keep a Changelog style. Conventional Commits, strict semver.',
      },
      {
        title: 'Publishing',
        description:
          'vanniktech publish plugin + signing with GPG Ed25519. Maven Central directly from v0.1. Coordinate io.github.miguelmialdeadev:formspec-*.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?fit=crop&w=900&h=600',
      alt: 'Build and testing',
    }}
  />

  <Stats
    title="What was delivered"
    subtitle="Tech library at the same level as Google's official ones."
    stats={[
      { title: 'Published modules', amount: '7' },
      { title: 'Critical test cases', amount: '5' },
      { title: 'Supported Compose versions', amount: '3' },
      { title: 'License', amount: 'Apache 2.0' },
    ]}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Let’s talk about your project',
        href: whatsappLink('Hi Codestack, I have seen Compose Forms and would like to talk about a technical project.'),
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
      {
        text: 'See more cases',
        href: '/en/cases',
      },
    ]}
  >
    <Fragment slot="title">Need real technical seniority?</Fragment>

    <Fragment slot="subtitle">
      For projects where technical quality matters: clean architecture, tests,
      performance, custom libraries. Tell me what you have in mind.
    </Fragment>
  </CallToAction>
</Layout>
