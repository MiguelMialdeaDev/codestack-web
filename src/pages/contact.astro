---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features3 from '~/components/widgets/Features3.astro';
import ContactUs from '~/components/widgets/Contact.astro';

import { whatsappLink } from '~/navigation';

const metadata = {
  title: 'Contacto — Codestack',
  description:
    'Tres formas de empezar la conversación: WhatsApp (rápido), email (formal), o un café presencial en tu local en Valencia.',
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <HeroText
    tagline="Contacto"
    title="Hablamos como tú prefieras"
    subtitle="Tres caminos para empezar — todos van a la misma persona (yo) y todos terminan con una propuesta clara en 48h si encajamos."
  />

  <!-- 3 opciones de contacto -->
  <Features3
    columns={3}
    items={[
      {
        title: 'WhatsApp (lo más rápido)',
        subtitle: 'Recomendado · Respuesta &lt;24h',
        description:
          'Mándame mensaje con qué tienes en mente. Lo más rápido y lo que mejor funciona para cliente Pyme. Sin formularios, sin esperas.',
        icon: 'tabler:brand-whatsapp',
        callToAction: {
          text: 'Abrir WhatsApp',
          href: whatsappLink('Hola Codestack, vengo de tu página de contacto y me interesa hablar de un proyecto.'),
          target: '_blank',
        },
      },
      {
        title: 'Email (más formal)',
        subtitle: 'Para propuestas detalladas',
        description:
          'Si prefieres dejar todo por escrito desde el primer minuto, escríbeme un email. Respondo dentro de 24h laborables.',
        icon: 'tabler:mail',
        callToAction: {
          text: 'Enviar email',
          href: 'mailto:miguelmialdeamonzo@gmail.com?subject=Codestack%20%E2%80%94%20Consulta%20de%20proyecto',
        },
      },
      {
        title: 'Visita a tu local',
        subtitle: 'Para leads premium en Valencia',
        description:
          'Si tienes un café o restaurante en Valencia y quieres hablar cara a cara: voy yo, tomamos un café, te enseño cómo lo haría. 15 minutos, sin compromiso.',
        icon: 'tabler:map-pin',
        callToAction: {
          text: 'Solicitar visita',
          href: whatsappLink('Hola Codestack, me gustaría que vinieses a mi local en Valencia para hablar 15 minutos. La dirección es [DIRECCIÓN].'),
          target: '_blank',
        },
      },
    ]}
  />

  <!-- Formulario backup para los que prefieren escribir directo -->
  <ContactUs
    id="form"
    tagline="O si prefieres formulario"
    title="Cuéntame tu situación"
    subtitle="También va a mi email. Sin pasos extra. Sin newsletter posterior."
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Tu nombre',
      },
      {
        type: 'email',
        name: 'email',
        label: 'Tu email',
      },
      {
        type: 'text',
        name: 'business',
        label: 'Nombre de tu negocio (opcional)',
      },
    ]}
    textarea={{
      label: 'Cuéntame qué tienes en mente, situación actual, o qué te gustaría conseguir',
      rows: 5,
    }}
    disclaimer={{
      label:
        'Al enviar aceptas que recibiré tu mensaje y te responderé. Tus datos solo se usan para esta conversación — más info en la política de privacidad.',
    }}
    description="Respuesta en menos de 24h laborables. Si encajamos, propuesta por escrito en 48h."
  />
</Layout>
